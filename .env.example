# ─────────────────────────────────────────────────────────────────────────────
# Gestion, environment configuration
# Copy to `.env` and adjust:  cp .env.example .env && docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres ─────────────────────────────────────────────────────────────────
# IMPORTANT: generate a real password before any non-local deploy:
#   openssl rand -hex 32
# The backend refuses to boot in production while this is still `change-me…`.
POSTGRES_USER=gestion
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=gestion
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full connection string consumed by Prisma (backend). Host `db` = compose service.
# Keep the password here in sync with POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://gestion:change-me-in-production@db:5432/gestion?schema=public

# NOTE: there is deliberately no SESSION_SECRET / JWT_SECRET. Sessions are opaque
# server-side DB rows (not signed tokens), so those keys were inert and were
# removed to avoid a false sense of protection.

# ── FX / currency ────────────────────────────────────────────────────────────
FX_PROVIDER=frankfurter
FX_FALLBACK_PROVIDER=erapi
FX_DEFAULT_BASE=EUR
# Optional base URLs / keys for providers (Frankfurter needs none):
FX_FRANKFURTER_URL=https://api.frankfurter.dev
FX_ERAPI_URL=https://open.er-api.com/v6

# ── App / runtime ────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Public URL. REQUIRED in production: it is the CORS allow-list origin (the backend
# refuses to start without it in prod and never reflects arbitrary origins) and it
# also drives the cookie Secure flag by default (https → Secure). Invite links too.
# It MUST match the scheme+host you actually reach the app on, or the browser will
# reject the auth cookies. The default below matches the `:80` HTTP dev run; for a
# real TLS deploy set it to your https:// hostname (see CADDY_SITE_ADDRESS).
APP_URL=http://localhost

# Session/CSRF cookie `Secure` flag. A `Secure` cookie is DROPPED by the browser over
# plain HTTP → login/registration fail with a CSRF/403. So:
#   COOKIE_SECURE=false  → plain-HTTP run (must match an http:// APP_URL + `:80` below)
#   COOKIE_SECURE=true   → HTTPS deploy (or leave unset to derive https from APP_URL)
# Default is false to match the out-of-the-box `:80` HTTP run; FLIP TO true (and use
# an https APP_URL + a TLS CADDY_SITE_ADDRESS) for any real/LAN deployment.
COOKIE_SECURE=false

# Where uploaded receipts are stored inside the backend container (uploads volume).
UPLOAD_DIR=/data/uploads
# Max upload size in bytes (10 MB) and allowed mime types (comma-separated).
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,application/pdf

# ── Caddy reverse proxy ──────────────────────────────────────────────────────
# TLS is REQUIRED for the LAN threat model: over plain HTTP the session cookie and
# all financial data traverse the LAN in cleartext (sniff / ARP-spoof). Prefer a
# hostname so Caddy provisions HTTPS automatically:
#   CADDY_SITE_ADDRESS=gestion.example.com   # public DNS  → Let's Encrypt
#   CADDY_SITE_ADDRESS=gestion.home          # LAN-only host → uncomment `tls internal`
#                                            #   in infra/Caddyfile (Caddy's internal CA)
# `:80` below is a DEV-ONLY convenience (no TLS). Do not use it for a real deploy;
# pair it with COOKIE_SECURE=false and an http:// APP_URL.
CADDY_SITE_ADDRESS=:80
# Email for Let's Encrypt (only used with a public hostname).
CADDY_ACME_EMAIL=admin@example.com

# ── Backups (db-backup sidecar) ──────────────────────────────────────────────
# Cron schedule for nightly pg_dump and how many daily dumps to retain.
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=14
